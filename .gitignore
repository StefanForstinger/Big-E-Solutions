## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# JetBrains Rider
.idea/
*.sln.iml

# Build outputs
*.dll
*.exe
*.pdb
*.cache
*.ilk
*.log
*.tlog
*.tmp
*.tmp_proj
*_wpftmp.csproj

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.meta
*.obj
*.iobj
*.pch
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp_proj
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Azure deployment credentials
PublishProfiles/
*.pubxml
*.publishproj

# Database files
*.mdf
*.ldf
*.ndf

# SQL Server files
*.bak

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# appsettings with secrets (keep template, ignore local)
appsettings.Development.json
appsettings.Local.json
